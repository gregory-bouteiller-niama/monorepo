{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "$lib": ["./src"],
      "$lib/*": ["./src/*"],
      "@niama/ui-svelte/utils/*": ["./src/lib/utils/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
