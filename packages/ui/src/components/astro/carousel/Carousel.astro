---
import type { HTMLAttributes } from "astro/types";
import type { EmblaOptionsType } from "embla-carousel";
import { CAROUSEL } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, orientation = "horizontal", opts = {}, autoInit = true, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & { autoInit?: boolean; opts?: EmblaOptionsType; orientation?: "horizontal" | "vertical" };
---

<div
  class:list={[CAROUSEL.base(), className]}
  role="region"
  aria-roledescription="carousel"
  data-axis={orientation === "horizontal" ? "x" : "y"}
  data-opts={JSON.stringify(opts)}
  data-auto-init={autoInit}
  {...rest}
  data-slot="carousel"
>
  <slot />
</div>

<script>
  import { initCarousel } from "./utils";

  const setupCarousels = () => {
    const carousels = document.querySelectorAll(".starwind-carousel") as NodeListOf<HTMLElement>;
    for (const carousel of carousels) {
      if (carousel.dataset.autoInit === "false") continue;
      initCarousel(carousel);
    }
  };

  document.addEventListener("DOMContentLoaded", setupCarousels);

  // Re-initialize after Astro page transitions
  document.addEventListener("astro:after-swap", setupCarousels);
</script>
