---
import type { HTMLAttributes } from "astro/types";
import { CAROUSEL } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className = "", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div">;
---

<div class={CAROUSEL.content()} {...rest} data-slot="carousel-content">
  <div class:list={[CAROUSEL.container(), className]} data-slot="carousel-container"><slot /></div>
</div>
