---
import Button from "../button/button.astro";
import { cn } from "@niama/ui/lib/utils";
import type { ComponentProps } from "astro/types";
import { CAROUSEL } from "../carousel";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className = "", variant = "outline", size = "icon", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = ComponentProps<typeof Button>;
---

<Button
  variant={variant}
  size={size}
  class={cn(CAROUSEL.previous(), className)}
  aria-label="Précédent"
  {...rest}
  data-slot="carousel-previous"
>
  <slot name="icon"> <span class="icon-[tabler--chevron-left]" /> </slot>
  <slot> <span class="sr-only">Précédent</span> </slot>
</Button>
