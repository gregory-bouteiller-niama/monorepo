---
import { Button } from "@niama/ui/astro/button";
import type { ComponentProps } from "astro/types";
import { carouselPrevious } from "./index.ts";

type Props = ComponentProps<typeof Button>;

const { class: className = "", variant = "outline", size = "icon", ...rest } = Astro.props;
---

<Button
  variant={variant}
  size={size}
  class:list={[carouselPrevious(), className]}
  aria-label="Previous slide"
  {...rest}
  data-slot="carousel-previous"
>
  <slot name="icon"> <span class="icon-[tabler--arrow-left]" /> </slot>
  <slot> <span class="sr-only">Previous slide</span> </slot>
</Button>
