---
import { Button } from "@niama/ui/astro/button";
import type { ComponentProps } from "astro/types";
import { CAROUSEL } from "../carousel";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className = "", variant = "outline", size = "icon", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = ComponentProps<typeof Button>;
---

<Button variant={variant} size={size} class:list={[CAROUSEL.next(), className]} aria-label="Suivant" {...rest} data-slot="carousel-next">
  <slot name="icon"> <span class="icon-[tabler--chevron-right]" /> </slot>
  <slot> <span class="sr-only">Suivant</span> </slot>
</Button>
