---
import type { HTMLAttributes } from "astro/types";
import { carouselItem } from "../carousel.ts";

type Props = HTMLAttributes<"div">;

const { class: className = "", ...rest } = Astro.props;
---

<div role="group" aria-roledescription="slide" class:list={[carouselItem(), className]} {...rest} data-slot="carousel-item"><slot /></div>
