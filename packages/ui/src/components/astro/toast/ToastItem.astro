---
import type { HTMLAttributes } from "astro/types";
import { type ToastItemStyles, toastClose, toastCloseIcon, toastContent, toastItem } from "./index.ts";

type Props = HTMLAttributes<"div"> & Pick<ToastItemStyles, "variant">;

const { class: className, variant = "default", ...rest } = Astro.props;
---

<div
  class:list={[toastItem({ variant }), className]}
  data-variant={variant}
  data-state="open"
  role="dialog"
  aria-modal="false"
  {...rest}
  data-slot="toast"
>
  <div class={toastContent()} data-slot="toast-content"><slot /></div>
  <button type="button" class={toastClose()} data-slot="toast-close" aria-label="Close notification">
    <span class={toastCloseIcon()} />
  </button>
</div>
