---
import type { HTMLAttributes } from "astro/types";
import { TOAST, type ToastItemStyles } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, variant = "default", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & Pick<ToastItemStyles, "variant">;
---

<div
  class:list={[TOAST.item({ variant }), className]}
  data-variant={variant}
  data-state="open"
  role="dialog"
  aria-modal="false"
  {...rest}
  data-slot="toast"
>
  <div class={TOAST.content()} data-slot="toast-content"><slot /></div>
  <button type="button" class={TOAST.close()} data-slot="toast-close" aria-label="Close notification">
    <span class={TOAST.closeIcon()} />
  </button>
</div>
