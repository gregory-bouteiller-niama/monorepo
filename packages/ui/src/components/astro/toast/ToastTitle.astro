---
import type { HTMLAttributes } from "astro/types";
import { type ToastTitleStyles, toastTitle, toastTitleIcons } from "../toast.ts";

type Props = HTMLAttributes<"div"> & Pick<ToastTitleStyles, "variant">;

const { class: className, variant = "default", ...rest } = Astro.props;
---

<div class:list={[toastTitle({ variant }), className]} data-slot="toast-title" data-toast-title {...rest}>
  <slot name="icon"> {variant !== "default" && <span class={toastTitleIcons[variant]} />} </slot>
  <span data-toast-title-text><slot /></span>
</div>
