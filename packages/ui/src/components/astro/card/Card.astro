---
import type { HTMLAttributes } from "astro/types";
import { type CardStyles, card } from "../card.ts";

type Props = HTMLAttributes<"div"> & CardStyles;

const { class: className, size, ...rest } = Astro.props;
---

<div class:list={[card({ size }), className]} data-size={size ?? "default"} {...rest} data-slot="card"><slot /></div>
