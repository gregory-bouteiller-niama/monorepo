---
import type { HTMLAttributes } from "astro/types";
import { CARD, type CardStyles } from "../card";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, size, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & CardStyles;
---

<div class:list={[CARD.base({ size }), className]} data-size={size ?? "default"} {...rest} data-slot="card"><slot /></div>
