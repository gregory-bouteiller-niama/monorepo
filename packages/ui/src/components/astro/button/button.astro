---
import { BUTTON, type ButtonStyles } from "@niama/ui/styles/button";
import type { HTMLAttributes } from "astro/types";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { variant, size, class: className, ...rest } = Astro.props;
const Tag = Astro.props.href ? "a" : "button";

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"button"> & Omit<HTMLAttributes<"a">, "type"> & ButtonStyles
---

<Tag class={BUTTON({ variant, size, class: className })} data-slot="button" {...rest}>
  <slot />
</Tag>
