---
import type { HTMLAttributes } from "astro/types";
import { DROPDOWN } from "../dropdown";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, asChild = false, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = Omit<HTMLAttributes<"button">, "role" | "type"> & {
  /**
   * When true, the component will render its child element with a simple wrapper instead of a button component
   */
  asChild?: boolean;
};

// Get the first child element if asChild is true
let hasChildren = false;
if (Astro.slots.has("default")) {
  hasChildren = true;
}
---

{asChild && hasChildren ? (
    <div
      class:list={[DROPDOWN.triggerAsChild(), className]}
      data-slot="dropdown-trigger"
      data-as-child
    >
      <slot />
    </div>
  ) : (
    <button
      class:list={[DROPDOWN.trigger(), className]}
      type="button"
      aria-haspopup="true"
      aria-expanded="false"
      data-state="closed"
      {...rest}
      data-slot="dropdown-trigger"
    >
      <slot />
    </button>
  )}
