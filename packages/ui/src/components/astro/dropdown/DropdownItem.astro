---
import type { HTMLTag, Polymorphic } from "astro/types";
import { type DropdownItemStyles, dropdownItem } from "../dropdown.ts";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & Pick<DropdownItemStyles, "disabled" | "inset">;

const { class: className, inset = false, disabled = false, as: Tag = "div", ...rest } = Astro.props;
---

<Tag
  class:list={[dropdownItem({ inset, disabled }), className]}
  role="menuitem"
  tabindex={disabled ? "-1" : "0"}
  data-disabled={disabled ? "true" : undefined}
  data-slot="dropdown-item"
  {...rest}
>
  <slot />
</Tag>
