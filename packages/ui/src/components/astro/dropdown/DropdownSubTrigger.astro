---
import type { HTMLAttributes } from "astro/types";

import { dropdownItem, dropdownSubTrigger, dropdownSubTriggerIcon } from "../dropdown.ts";

type Props = HTMLAttributes<"div"> & {
  /**
   * Whether the item is inset (has left padding)
   */
  inset?: boolean;
  /**
   * Whether the item is disabled
   */
  disabled?: boolean;
};

const { class: className, inset = false, disabled = false, ...rest } = Astro.props;
---

<div
  class:list={[dropdownItem({ inset, disabled }), dropdownSubTrigger(), className]}
  role="menuitem"
  aria-haspopup="true"
  aria-expanded="false"
  tabindex={disabled ? "-1" : "0"}
  data-disabled={disabled ? "true" : undefined}
  data-sub-trigger
  {...rest}
  data-slot="dropdown-item"
>
  <slot />
  <span class={dropdownSubTriggerIcon()} />
</div>
