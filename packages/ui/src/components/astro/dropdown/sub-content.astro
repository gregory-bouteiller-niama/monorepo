---
import type { HTMLAttributes } from "astro/types";
import { DROPDOWN } from "../dropdown";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, animationDuration = 150, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & {
  /**
   * Open and close animation duration in milliseconds
   * @default 150
   */
  animationDuration?: number;
};
---

<div
  class:list={[DROPDOWN.content({ side: "right", align: "start" }), DROPDOWN.subContent(), className]}
  data-sub-content
  role="menu"
  data-preferred-align="start"
  data-preferred-side="right"
  data-side="right"
  data-align="start"
  data-side-offset="0"
  data-state="closed"
  tabindex="-1"
  aria-orientation="vertical"
  style={{
    display: "none",
    animationDuration: `${animationDuration}ms`,
  }}
  {...rest}
  data-slot="dropdown-content"
>
  <slot />
</div>
