---
import type { HTMLTag, Polymorphic } from "astro/types";
import { DROPDOWN, type DropdownItemStyles } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, inset = false, disabled = false, as: Tag = "div", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props<Tag extends HTMLTag = "div"> = Polymorphic<{ as: Tag }> & Pick<DropdownItemStyles, "disabled" | "inset">;
---

<Tag
  class:list={[DROPDOWN.item({ inset, disabled }), className]}
  role="menuitem"
  tabindex={disabled ? "-1" : "0"}
  data-disabled={disabled ? "true" : undefined}
  data-slot="dropdown-item"
  {...rest}
>
  <slot />
</Tag>
