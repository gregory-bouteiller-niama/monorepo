---
import type { HTMLAttributes } from "astro/types";
import { DROPDOWN } from "../dropdown";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, side = "bottom", align = "start", sideOffset = 4, animationDuration = 150, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & {
  /**
   * Side of the dropdown
   * @default bottom
   */
  side?: "top" | "bottom" | "left" | "right";
  /**
   * Alignment of the dropdown
   * @default start
   */
  align?: "start" | "center" | "end";
  /**
   * Offset distance in pixels
   * @default 4
   */
  sideOffset?: number;
  /**
   * Open and close animation duration in milliseconds
   * @default 150
   */
  animationDuration?: number;
};
---

<div
  class:list={[DROPDOWN.content({ side, align }), className]}
  role="menu"
  data-side={side}
  data-align={align}
  data-state="closed"
  tabindex="-1"
  aria-orientation="vertical"
  style={{
    display: "none",
    animationDuration: `${animationDuration}ms`,
    marginTop: side === "bottom" ? `${sideOffset}px` : undefined,
    marginBottom: side === "top" ? `${sideOffset}px` : undefined,
    marginLeft: side === "right" ? `${sideOffset}px` : undefined,
    marginRight: side === "left" ? `${sideOffset}px` : undefined,
  }}
  {...rest}
  data-slot="dropdown-content"
>
  <slot />
</div>
