---
import type { HTMLAttributes } from "astro/types";
import { DROPDOWN } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, inset = false, disabled = false, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & {
  /**
   * Whether the item is inset (has left padding)
   */
  inset?: boolean;
  /**
   * Whether the item is disabled
   */
  disabled?: boolean;
};
---

<div
  class:list={[DROPDOWN.item({ inset, disabled }), DROPDOWN.subTrigger(), className]}
  role="menuitem"
  aria-haspopup="true"
  aria-expanded="false"
  tabindex={disabled ? "-1" : "0"}
  data-disabled={disabled ? "true" : undefined}
  data-sub-trigger
  {...rest}
  data-slot="dropdown-item"
>
  <slot />
  <span class={DROPDOWN.subTriggerIcon()} />
</div>
