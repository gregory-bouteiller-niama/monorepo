---
import { cn } from "@niama/ui/lib/utils";
import type { HTMLAttributes } from "astro/types";
import { ITEM, type ItemMediaStyles } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { variant = "default", class: className, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & Pick<ItemMediaStyles, "variant">;
---

<div class={cn(ITEM.media({ variant }), className)} data-variant={variant} {...rest} data-slot="item-media"><slot /></div>
