---
import type { HTMLAttributes } from "astro/types";
import { type ItemMediaStyles, itemMedia } from "./index.ts";

type Props = HTMLAttributes<"div"> & Pick<ItemMediaStyles, "variant">;

const { variant = "default", class: className, ...rest } = Astro.props;
---

<div class:list={[itemMedia({ variant }), className]} data-variant={variant} {...rest} data-slot="item-media"><slot /></div>
