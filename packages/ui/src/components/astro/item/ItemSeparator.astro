---
import { Separator } from "@niama/ui/astro/separator";
import type { ComponentProps } from "astro/types";
import { itemSeparator } from "../item.ts";

type Props = ComponentProps<typeof Separator>;

const { class: className, orientation = "horizontal", ...rest } = Astro.props;
---

<Separator orientation={orientation} class:list={[itemSeparator(), className]} {...rest} data-slot="item-separator" />
