---
import { Separator as SeparatorNative } from "@niama/ui/astro/separator";
import type { ComponentProps } from "astro/types";
import { ITEM } from "../item";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, orientation = "horizontal", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = ComponentProps<typeof SeparatorNative>;
---

<SeparatorNative orientation={orientation} class:list={[ITEM.separator(), className]} {...rest} data-slot="item-separator" />
