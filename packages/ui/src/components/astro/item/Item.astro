---
import type { HTMLTag, Polymorphic } from "astro/types";
import { type ItemStyles, item } from "../item.ts";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & Pick<ItemStyles, "size" | "variant">;

const { variant = "default", size = "default", class: className, as: Tag = "div", ...rest } = Astro.props;
---

<Tag class:list={[item({ variant, size }), className]} data-slot="item" {...rest}> <slot /> </Tag>
