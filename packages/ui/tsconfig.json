{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@niama/ui/*": ["./src/*"],
      "@niama/ui/astro/*": ["./src/components/astro/*"],
      "@niama/ui/react/*": ["./src/components/react/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
