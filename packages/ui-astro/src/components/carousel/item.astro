---
import { CAROUSEL } from "@niama/ui/carousel";
import { cn } from "@niama/ui/lib/utils";
import type { HTMLAttributes } from "astro/types";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className = "", ...props } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"section">;
---

<section aria-roledescription="slide" class={cn(CAROUSEL.item(), className)} data-slot="carousel-item" role="group" {...props}>
  <slot />
</section>
