---
import { cn } from "@niama/ui-astro/lib/utils";
import type { HTMLTag, Polymorphic } from "astro/types";
import { ITEM, type ItemStyles } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { variant = "default", size = "default", class: className, as: Tag = "div", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props<Tag extends HTMLTag = "div"> = Polymorphic<{ as: Tag }> & Pick<ItemStyles, "size" | "variant">;
---

<Tag class={cn(ITEM.base({ variant, size }), className)} data-slot="item" {...rest}> <slot /> </Tag>
