---
import { DEFAULT_THEME_SWITCHER_LABEL, THEME_SWITCHER } from "@niama/ui/theme-switcher";
import { Button } from "@niama/ui-astro/ui/button";
---

<theme-switcher>
  <Button
    aria-label={DEFAULT_THEME_SWITCHER_LABEL}
    aria-pressed={false}
    class={THEME_SWITCHER.base()}
    data-slot="theme-switcher"
    size="icon"
    type="button"
    variant="outline"
  >
    <span class={THEME_SWITCHER.sun()} />
    <span class={THEME_SWITCHER.moon()} />
    <span class="sr-only">{DEFAULT_THEME_SWITCHER_LABEL}</span>
  </Button>
</theme-switcher>

<script>
  import { type AppTheme, themeStore, toggleThemeWithTransition } from "@niama/ui/theme";
  import { getThemeSwitcherLabel } from "@niama/ui/theme-switcher";

  const ThemeSwitcher = class extends HTMLElement {
    cleanups: (() => void)[] = [];

    connectedCallback() {
      const switcher = this.querySelector<HTMLElement>('[data-slot="theme-switcher"]');
      if (!switcher) throw new Error("Theme switcher root element not found");

      const syncThemeSwitcher = (theme: AppTheme) => {
        const label = getThemeSwitcherLabel(theme);
        switcher.setAttribute("aria-label", label);
        switcher.setAttribute("aria-pressed", (theme === "dark").toString());
        switcher.setAttribute("title", label);
      };

      syncThemeSwitcher(themeStore.get());
      const { unsubscribe } = themeStore.subscribe(syncThemeSwitcher);
      this.cleanups.push(unsubscribe);

      const handleClick = () => toggleThemeWithTransition(switcher);

      switcher.addEventListener("click", handleClick);
      this.cleanups.push(() => switcher.removeEventListener("click", handleClick));
    }

    disconnectedCallback() {
      for (const cleanup of this.cleanups) cleanup();
      this.cleanups = [];
    }
  };
  if (!customElements.get("theme-switcher")) customElements.define("theme-switcher", ThemeSwitcher);
</script>
