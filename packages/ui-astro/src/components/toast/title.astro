---
import type { HTMLAttributes } from "astro/types";
import { TOAST, type ToastTitleStyles } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, variant = "default", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & Pick<ToastTitleStyles, "variant">;
---

<div class:list={[TOAST.title({ variant }), className]} data-slot="toast-title" data-toast-title {...rest}>
  <slot name="icon"> {variant !== "default" && <span class={TOAST.titleIcons[variant]} />} </slot>
  <span data-toast-title-text><slot /></span>
</div>
