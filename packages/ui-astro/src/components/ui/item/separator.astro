---
import { cn } from "@niama/ui-astro/lib/utils";
import type { ComponentProps } from "astro/types";
import SeparatorNative from "../separator/separator.astro";
import { ITEM } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, orientation = "horizontal", ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = ComponentProps<typeof SeparatorNative>;
---

<SeparatorNative orientation={orientation} class={cn(ITEM.separator(), className)} {...rest} data-slot="item-separator" />
