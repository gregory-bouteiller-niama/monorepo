---
import { cn } from "@niama/ui-astro/lib/utils";
import type { HTMLAttributes } from "astro/types";
import { CARD, type CardStyles } from "./styles";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className, size, ...rest } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"div"> & CardStyles;
---

<div class={cn(CARD.base({ size }), className)} data-size={size ?? "default"} {...rest} data-slot="card"><slot /></div>
