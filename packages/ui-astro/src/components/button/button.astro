---
import { BUTTON, type ButtonStyles } from "@niama/ui/button";
import { cn } from "@niama/ui/lib/utils";
import type { HTMLAttributes } from "astro/types";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { variant, size, class: className, ...rest } = Astro.props;
const Tag = Astro.props.href ? "a" : "button";

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
export type Props = HTMLAttributes<"button"> & Omit<HTMLAttributes<"a">, "type"> & ButtonStyles;
---

<Tag class={cn(BUTTON({ variant, size }), className)} data-slot="button" {...rest}><slot /></Tag>
