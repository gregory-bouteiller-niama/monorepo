---
import type { ReadPublicLayoutProps } from "@niama/domain/functions/layouts";
import { THE_HEADER } from "@niama/ui/the-header";
import { ThemeSwitcher } from "@niama/ui-astro/theme-switcher";
import { Button } from "@niama/ui-astro/ui/button";
import { Dropdown, DropdownContent, DropdownItem, DropdownTrigger } from "@niama/ui-astro/ui/dropdown";
import { Logo } from "@niama/ui-astro/ui/logo";
import { Section } from "@niama/ui-react/ui/section";
import { Separator } from "@niama/ui-react/ui/separator";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { navs } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
type Props = Pick<ReadPublicLayoutProps, "navs">;
---

<div class={THE_HEADER.wrapper()}>
  <header class={THE_HEADER.base()}>
    <a aria-label="Retour à l'accueil" class={THE_HEADER.logo()} href="/#top"> <Logo showTitle={false} /> </a>

    <div class={THE_HEADER.actions()}>
      <Dropdown>
        <DropdownTrigger asChild>
          <Button aria-label="Menu principal" class={THE_HEADER.burger()} size="icon" variant="outline">
            <span class={THE_HEADER.burgerIcon()}></span>
          </Button>
        </DropdownTrigger>
        <DropdownContent align="end" class={THE_HEADER.burgerContent()} sideOffset={18}>
          {navs.map(({ hash, text, to }) => (
							<DropdownItem class={THE_HEADER.burgerItem()}>
								<a href={`${to}#${hash}`}>{text}</a>
							</DropdownItem>
						))}
        </DropdownContent>
      </Dropdown>
      <ThemeSwitcher />
    </div>
  </header>
</div>
<Section className="flex justify-center" id="top">
  <a aria-label="Retour à l'accueil" class={THE_HEADER.logoMain()} href="/#top"> <Logo class="w-full" /> </a>
</Section>
<Separator className="self-center! h-6" orientation="vertical" />
<Section className={THE_HEADER.menu()} id="top-2">
  <nav aria-label="Navigation principale" class={THE_HEADER.nav()} data-nav>
    <div aria-hidden="true" class={THE_HEADER.stain()} data-nav-stain></div>
    {navs.map(({ hash, text, to }) => (
				<Button class={THE_HEADER.navLink()} data-nav-link={hash} href={`${to}#${hash}`} variant="ghost">
					{text}
				</Button>
			))}
  </nav>
</Section>
<Separator className="self-center! h-24" orientation="vertical" />

<script>
  import { initialize } from "@niama/ui/the-header";

  initialize();
</script>
