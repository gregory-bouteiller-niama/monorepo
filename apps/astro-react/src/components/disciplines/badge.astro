---
import { type Disciplines, readDisciplineBySlug } from "@niama/domain/functions/disciplines";
import { DISCIPLINES_BADGE } from "@niama/ui/disciplines/badge";
import { cn } from "@niama/ui/lib/utils";
import { type BadgeProps, Badge as BadgeReact } from "@niama/ui-react/badge";

// MAIN ------------------------------------------------------------------------------------------------------------------------------------
const { className, slug, ...props } = Astro.props;

// DATA ------------------------------------------------------------------------------------------------------------------------------------
const { title } = readDisciplineBySlug(slug);

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
type Props = BadgeProps & { slug: Disciplines["Entity"]["slug"] };
---

<BadgeReact {...props} className={cn(DISCIPLINES_BADGE(), className)} data-discipline={slug}> {title} </BadgeReact>
