---
import { type Disciplines, readDisciplineBySlug } from "@niama/domain/functions/disciplines";
import { DISCIPLINES_BADGE } from "@niama/ui/disciplines/badge";
import { cn } from "@niama/ui-astro/lib/utils";
import { Badge } from "@niama/ui-svelte/badge";

const { class: className, slug, ...restProps } = Astro.props;

const { title } = readDisciplineBySlug(slug);

type Props = { class?: string; slug: Disciplines["Entity"]["slug"] };
---

<Badge {...restProps} class={cn(DISCIPLINES_BADGE(), className)} data-discipline={slug}> {title} </Badge>
