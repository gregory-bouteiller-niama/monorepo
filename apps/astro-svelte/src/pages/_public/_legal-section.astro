---
import type { ReadLegalPageProps } from "@niama/domain/functions/pages";
import { Button } from "@niama/ui-svelte/button";
import { Card, CardContent, CardHeader, CardTitle } from "@niama/ui-svelte/card";
import { Section } from "@niama/ui-svelte/section";
import { cva } from "class-variance-authority";

const LEGAL_SECTION = {
  content: cva("space-y-3 text-sm leading-7 md:text-base"),
  title: cva("font-bold text-3xl"),
};

const LEGAL_SECTIONS = {
  base: cva("mx-auto max-w-7xl"),
  container: cva("grid w-full gap-4 md:grid-cols-2"),
};

const { section, withSeparator = true } = Astro.props;

type LegalSection = ReadLegalPageProps["legal"] | ReadLegalPageProps["privacy"];
type Props = { section: LegalSection; withSeparator?: boolean };
---

<Section
  class={LEGAL_SECTIONS.base()}
  description={section.description}
  id={section.id}
  title={section.title}
  {withSeparator}
>
  <div class={LEGAL_SECTIONS.container()}>
    {section.cards.map(({ content, title }) => (
      <Card>
        <CardHeader>
          <CardTitle class={LEGAL_SECTION.title()}>{title}</CardTitle>
        </CardHeader>
        <CardContent class={LEGAL_SECTION.content()}>
          {
            content.map((paragraph) =>
              typeof paragraph === "string" ? (
                <p>{paragraph}</p>
              ) : (
                <p>
                  {paragraph.prefix}
                  <Button class="text-base" href={`mailto:${paragraph.email}`} size="xs" variant="link">
                    {paragraph.email}
                  </Button>
                </p>
              )
            )
          }
        </CardContent>
      </Card>
    ))}
  </div>
</Section>
