---
import { Image } from "astro:assets";
import { Carousel, CarouselContent, CarouselItem, CarouselNext, CarouselPrevious } from "@niama/ui/astro/carousel";
import { ATTENDANTS, AUTOPLAY, getAttendantsHeroRotation } from "@niama/ui/shared/attendants/carousel";
import DisciplinesBadge from "@/components/disciplines/badge.astro";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { autoplay = AUTOPLAY / 1000, class: className = "", items } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
type AttendantDiscipline = {
  slug: string;
};

type AttendantImage = {
  alt: string;
  height: number;
  src: string;
  width: number;
};

type AttendantItem = {
  description: string[];
  disciplines: AttendantDiscipline[];
  image: AttendantImage;
  name: string;
};

type Props = {
  autoplay?: number;
  class?: string;
  items: AttendantItem[];
};
---

<section class:list={[ATTENDANTS.base(), className]} data-attendants-autoplay={autoplay} data-attendants-carousel>
  <Carousel
    autoInit={false}
    class={ATTENDANTS.carousel()}
    data-attendants-images
    opts={{ align: "center", containScroll: false, loop: true }}
  >
    <CarouselContent class="-ml-4" viewportClassName={ATTENDANTS.heroViewport()}>
      {items.map((attendant, index) => (
        <CarouselItem class={ATTENDANTS.heroItem()}>
          <button
            aria-label={`Afficher la fiche de ${attendant.name}`}
            aria-pressed="false"
            class={ATTENDANTS.heroCard()}
            data-attendants-card
            data-flipped="false"
            type="button"
          >
            <div
              class={ATTENDANTS.heroInner()}
              data-attendants-card-inner
              data-attendants-rotation={getAttendantsHeroRotation(attendant.name)}
              style={`--attendants-rotation:${index === 0 ? 0 : getAttendantsHeroRotation(attendant.name)}deg;--attendants-y-rotation:0deg;`}
            >
              <article class:list={[ATTENDANTS.heroFigure(), ATTENDANTS.heroFace()]}>
                <Image
                  {...attendant.image}
                  class={ATTENDANTS.heroImage()}
                  format="avif"
                  sizes="(min-width: 1280px) 896px, (min-width: 1024px) 768px, (min-width: 768px) 704px, (min-width: 640px) 576px, 100vw"
                  widths={[896, 1152, 1408, 1792]}
                />
                <div class={ATTENDANTS.heroOverlay()} />
                <div class={ATTENDANTS.heroHoverOverlay()} />
                <div class={ATTENDANTS.heroHoverIcon()}>En savoir plus...</div>
                <div class={ATTENDANTS.heroContent()}>
                  <h3 class={ATTENDANTS.heroName()}>{attendant.name}</h3>
                  <div class={ATTENDANTS.heroDisciplines()}>
                    {attendant.disciplines.map((discipline) => (
                      <DisciplinesBadge class={ATTENDANTS.heroBadge()} slug={discipline.slug} />
                    ))}
                  </div>
                </div>
              </article>
              <div class={ATTENDANTS.heroBackFace()}>
                <div class={ATTENDANTS.heroBackBody()}>
                  <div class={ATTENDANTS.heroDescription()}>
                    {attendant.description.map((paragraph) => (
                      <p>{paragraph}</p>
                    ))}
                  </div>
                </div>
                <div class={ATTENDANTS.heroBackFooter()}>
                  <h3 class={ATTENDANTS.heroName()}>{attendant.name}</h3>
                  <div class={ATTENDANTS.heroDisciplines()}>
                    {attendant.disciplines.map((discipline) => (
                      <DisciplinesBadge class={ATTENDANTS.heroBadge()} slug={discipline.slug} />
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </button>
        </CarouselItem>
      ))}
    </CarouselContent>
    <div class={ATTENDANTS.actions()}>
      <CarouselPrevious aria-label="Participant precedent" class={ATTENDANTS.control()} disabled={items.length < 2} size="icon-sm" />
      <CarouselNext aria-label="Participant suivant" class={ATTENDANTS.control()} disabled={items.length < 2} size="icon-sm" />
    </div>
  </Carousel>
</section>

<script>
  import { initCarousel } from "@niama/ui/astro/carousel";
  import Autoplay from "embla-carousel-autoplay";

  const carouselCleanups = new WeakMap<HTMLElement, () => void>();

  const destroyAttendantsCarousels = () => {
    const carousels = document.querySelectorAll("[data-attendants-carousel]") as NodeListOf<HTMLElement>;

    for (const carousel of carousels) {
      carouselCleanups.get(carousel)?.();
    }
  };

  const initializeAttendantsCarousels = () => {
    const carousels = document.querySelectorAll("[data-attendants-carousel]") as NodeListOf<HTMLElement>;

    for (const carousel of carousels) {
      if (carouselCleanups.has(carousel)) {
        continue;
      }

      const carouselElement = carousel.querySelector("[data-attendants-images]");

      if (!(carouselElement instanceof HTMLElement)) {
        continue;
      }

      const autoplaySeconds = Number(carousel.dataset.attendantsAutoplay ?? Number.NaN);
      const plugins =
        Number.isFinite(autoplaySeconds) && autoplaySeconds > 0
          ? [Autoplay({ delay: autoplaySeconds * 1000, stopOnInteraction: false })]
          : undefined;
      const manager = initCarousel(carouselElement, { opts: { align: "center", containScroll: false, loop: true }, plugins });

      if (!manager) {
        continue;
      }

      const syncActiveCards = () => {
        const selectedIndex = manager.api.selectedScrollSnap();
        const cardInners = carousel.querySelectorAll("[data-attendants-card-inner]") as NodeListOf<HTMLElement>;

        for (const [index, inner] of Array.from(cardInners).entries()) {
          const baseRotation = Number(inner.dataset.attendantsRotation ?? 0);
          inner.style.setProperty("--attendants-rotation", `${index === selectedIndex ? 0 : baseRotation}deg`);
        }
      };

      syncActiveCards();
      manager.api.on("reInit", syncActiveCards);
      manager.api.on("select", syncActiveCards);

      const cards = carousel.querySelectorAll("[data-attendants-card]") as NodeListOf<HTMLButtonElement>;
      const cardClickHandlers = Array.from(cards, (card) => {
        const handleCardClick = () => {
          const isFlipped = card.dataset.flipped === "true";

          for (const otherCard of cards) {
            otherCard.dataset.flipped = "false";
            otherCard.setAttribute("aria-pressed", "false");
            const inner = otherCard.querySelector("[data-attendants-card-inner]") as HTMLElement | null;
            inner?.style.setProperty("--attendants-y-rotation", "0deg");
          }

          if (isFlipped) {
            return;
          }

          card.dataset.flipped = "true";
          card.setAttribute("aria-pressed", "true");
          const inner = card.querySelector("[data-attendants-card-inner]") as HTMLElement | null;
          inner?.style.setProperty("--attendants-y-rotation", "180deg");
        };

        card.addEventListener("click", handleCardClick);
        return { card, handleCardClick };
      });

      carouselCleanups.set(carousel, () => {
        manager.api.off("reInit", syncActiveCards);
        manager.api.off("select", syncActiveCards);
        for (const { card, handleCardClick } of cardClickHandlers) {
          card.removeEventListener("click", handleCardClick);
        }
        manager.destroy();
        carouselCleanups.delete(carousel);
      });
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeAttendantsCarousels, { once: true });
  } else {
    initializeAttendantsCarousels();
  }

  document.addEventListener("astro:after-swap", initializeAttendantsCarousels);
  document.addEventListener("astro:before-swap", destroyAttendantsCarousels);
</script>
