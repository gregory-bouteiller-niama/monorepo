---
// import type { DisciplineTone } from "@niama/domain/functions/disciplines";
import { Image } from "astro:assets";
import {Button} from "@niama/ui/astro/button/index.ts";
import { CardContent, CardDescription, CardHeader, CardTitle } from "@niama/ui/astro/card/index.ts";
import { ATTENDANTS } from "@niama/ui/styles/attendants/carousel";
import DisciplinesBadge from "@/components/disciplines/badge.astro";
import Glow from "@/components/glow.astro";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { autoplay = Number.NaN, class: className = "", items } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
type AttendantDiscipline = {
  key: DisciplineTone;
  label: string;
};

type AttendantImage = {
  alt: string;
  height: number;
  src: string;
  width: number;
};

type AttendantItem = {
  description: string[];
  disciplines: AttendantDiscipline[];
  image: AttendantImage;
  name: string;
};

type Props = {
  autoplay?: number;
  class?: string;
  items: AttendantItem[];
};

const getImageStatus = (index: number) => {
  if (index === 0) return ATTENDANTS.imageCurrent();
  if (index === 1) return ATTENDANTS.imageNext();
  if (index === items.length - 1) return ATTENDANTS.imagePrev();
  return ATTENDANTS.imageOther();
};
---

<div class:list={[ATTENDANTS.base(), className]} data-attendants-autoplay={autoplay} data-attendants-carousel data-size={items.length}>
  <aside class={ATTENDANTS.aside()}>
    {items.map((attendant, index) => (
      <Image
        alt={attendant.image.alt}
        data-index={index}
        data-slot="attendant-image"
        densities={[1.5, 2]}
        format="avif"
        height={attendant.image.height}
        class:list={[ATTENDANTS.image(), getImageStatus(index)]}
        loading={index === 0 ? "eager" : "lazy"}
        sizes="(max-width: 768px) 70vw, 40vw"
        src={attendant.image.src}
        widths={[480, 720, 960, 1200]}
        width={attendant.image.width}
      />
    ))}
  </aside>
  <main class={ATTENDANTS.main()}>
    <div class={ATTENDANTS.panelContainer()}>
      {items.map((attendant, index) => (
        <div class={ATTENDANTS.cardPanel()} data-index={index} data-slot="attendant-panel" data-state={index === 0 ? "active" : "inactive"}>
          <Glow class={ATTENDANTS.card()} kind="card">
            <CardHeader>
              <CardTitle class={ATTENDANTS.name()}>{attendant.name}</CardTitle>
              <CardDescription class={ATTENDANTS.disciplines()}>
                {attendant.disciplines.map((discipline) => (
                  <DisciplinesBadge class={ATTENDANTS.badge()} slug={discipline.slug} />
                ))}
              </CardDescription>
            </CardHeader>
            <CardContent class={ATTENDANTS.description()}>
              {attendant.description.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </CardContent>
          </Glow>
        </div>
      ))}
    </div>
    <div class={ATTENDANTS.actions()}>
      <Button aria-label="Participant precedent" class="cursor-pointer" data-attendants-prev size="icon-sm" variant="outline">
        <span class="icon-[lucide--chevron-left]"></span>
      </Button>
      <Button aria-label="Participant suivant" class="cursor-pointer" data-attendants-next size="icon-sm" variant="outline">
        <span class="icon-[lucide--chevron-right]"></span>
      </Button>
    </div>
  </main>
</div>

<script>
  const initializeAttendantsCarousels = () => {
      const carousels = document.querySelectorAll("[data-attendants-carousel]") as NodeListOf<HTMLElement>;

      for (const carousel of carousels) {
        if (carousel.dataset.initialized === "true") {
          continue;
        }

        const previousButton = carousel.querySelector("[data-attendants-prev]");
        const nextButton = carousel.querySelector("[data-attendants-next]");
        const images = carousel.querySelectorAll("[data-slot='attendant-image']") as NodeListOf<HTMLElement>;
        const panels = carousel.querySelectorAll("[data-slot='attendant-panel']") as NodeListOf<HTMLElement>;
        const size = Number(carousel.dataset.size ?? "0");

        if (!(previousButton instanceof HTMLElement && nextButton instanceof HTMLElement) || size === 0) {
          continue;
        }

        carousel.dataset.initialized = "true";

        let activeIndex = 0;
        let autoplayId = 0;
        const autoplaySeconds = Number(carousel.dataset.attendantsAutoplay ?? Number.NaN);

        const getStatus = (index: number) => {
          if (index === activeIndex) return "current";
          if ((activeIndex - 1 + size) % size === index) return "prev";
          if ((activeIndex + 1) % size === index) return "next";
          return "other";
        };

        const updateView = () => {
          for (const image of images) {
            const index = Number(image.dataset.index ?? "-1");
            image.dataset.status = getStatus(index);

            image.classList.toggle("translate-x-0", image.dataset.status === "current");
            image.classList.toggle("translate-y-0", image.dataset.status === "current");
            image.classList.toggle("rotate-y-0", image.dataset.status === "current");
            image.classList.toggle("scale-100", image.dataset.status === "current");
            image.classList.toggle("opacity-100", image.dataset.status !== "other");
            image.classList.toggle("z-40", image.dataset.status === "current");
            image.classList.toggle("pointer-events-auto", image.dataset.status !== "other");

            image.classList.toggle("translate-x-15", image.dataset.status === "next");
            image.classList.toggle("-translate-y-12", image.dataset.status === "next" || image.dataset.status === "prev");
            image.classList.toggle("-rotate-y-15", image.dataset.status === "next");
            image.classList.toggle("scale-85", image.dataset.status === "next" || image.dataset.status === "prev");
            image.classList.toggle("z-30", image.dataset.status === "next");

            image.classList.toggle("-translate-x-15", image.dataset.status === "prev");
            image.classList.toggle("rotate-y-15", image.dataset.status === "prev");
            image.classList.toggle("z-20", image.dataset.status === "prev");

            image.classList.toggle("pointer-events-none", image.dataset.status === "other");
            image.classList.toggle("opacity-0", image.dataset.status === "other");
            image.classList.toggle("z-10", image.dataset.status === "other");
          }

          for (const panel of panels) {
            const index = Number(panel.dataset.index ?? "-1");
            panel.dataset.state = index === activeIndex ? "active" : "inactive";
          }
        };

        const stopAutoplay = () => {
          if (autoplayId) {
            window.clearInterval(autoplayId);
            autoplayId = 0;
          }
        };

        const goTo = (index: number, fromUser = false) => {
          activeIndex = (index + size) % size;
          updateView();

          if (fromUser) {
            stopAutoplay();
          }
        };

        const handleNext = () => {
          goTo(activeIndex + 1, true);
        };

        const handlePrev = () => {
          goTo(activeIndex - 1, true);
        };

        previousButton.addEventListener("click", handlePrev);
        nextButton.addEventListener("click", handleNext);

        window.addEventListener("keydown", (event) => {
          if (event.key === "ArrowLeft") {
            handlePrev();
          }
          if (event.key === "ArrowRight") {
            handleNext();
          }
        });

        if (!Number.isNaN(autoplaySeconds)) {
          autoplayId = window.setInterval(() => {
            goTo(activeIndex + 1);
          }, autoplaySeconds * 1000);
        }

        updateView();
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initializeAttendantsCarousels, { once: true });
    } else {
      initializeAttendantsCarousels();
    }

    document.addEventListener("astro:after-swap", initializeAttendantsCarousels);
</script>
