---
import { Image } from "astro:assets";
import type { Attendants } from "@niama/domain/functions/attendants";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@niama/ui/astro/card.ts";
import { CarouselContent, CarouselItem, Carousel as CarouselNative, CarouselNext, CarouselPrevious } from "@niama/ui/astro/carousel.ts";
import { ATTENDANT, ATTENDANTS, ROTATIONS } from "@niama/ui/shared/attendants/carousel";
import DisciplinesBadge from "@/components/disciplines/badge.astro";

// PROPS -----------------------------------------------------------------------------------------------------------------------------------
const { class: className = "", items } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
type Props = { class?: string; items: Attendants["Entity"][] };
---

<attendants-carousel class:list={[ATTENDANTS.base(), className]}>
  <CarouselNative class={ATTENDANTS.carousel()}>
    <CarouselContent viewportClass={ATTENDANTS.viewport()}>
      {items.map((attendant, index) => (
          <CarouselItem class={ATTENDANTS.item()}>
            <button
              aria-label={`Afficher la fiche de ${attendant.name}`}
              aria-pressed="false"
              data-attendant
              data-flipped="false"
              class:list={[ATTENDANT.base(), ROTATIONS[index % ROTATIONS.length]]}
              type="button"
            >
              <Card class={ATTENDANT.card()}>
                <CardHeader>
                  <CardTitle class={ATTENDANT.title()}>{attendant.name}</CardTitle>
                  <CardDescription class={ATTENDANT.badges()}>
                    {attendant.disciplines.map((discipline) => (
                      <DisciplinesBadge slug={discipline.slug} />
                    ))}
                  </CardDescription>
                </CardHeader>
                <CardContent class={ATTENDANT.image()}>
                  <div class={ATTENDANT.overlay()}>
                    <span class={ATTENDANT.icon()} />
                  </div>
                  <Image
                    {...attendant.image}
                    format="avif"
                    sizes="(min-width: 640px) 420px, 100vw"
                    widths={[420, 840]}
                  />
                </CardContent>
              </Card>
              <Card class={ATTENDANT.card()} data-back>
                <CardHeader>
                  <CardTitle class={ATTENDANT.title()}>{attendant.name}</CardTitle>
                  <CardDescription class={ATTENDANT.badges()}>
                    {attendant.disciplines.map((discipline) => (
                      <DisciplinesBadge slug={discipline.slug} />
                    ))}
                  </CardDescription>
                </CardHeader>
                <CardContent class={ATTENDANT.description()}>
                  {attendant.description.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </CardContent>
              </Card>
            </button>
          </CarouselItem>
        ))}
    </CarouselContent>
    <aside class={ATTENDANTS.controls()}>
      <CarouselPrevious class={ATTENDANTS.control()} />
      <CarouselNext class={ATTENDANTS.control()} />
    </aside>
  </CarouselNative>
</attendants-carousel>

<script>
  import { defineCarousel, initCarousel } from "@niama/ui/astro/carousel.ts";
  import { AUTOPLAY } from "@niama/ui/shared/attendants/carousel";
  import Autoplay from "embla-carousel-autoplay";

  defineCarousel({
    name: "attendants-carousel",
    setup: (el) => {
      const destroyCarousel = initCarousel(el, { loop: true }, [Autoplay({ delay: AUTOPLAY })]);
      const handleClick = (event: Event) => {
        const el = event.target;
        if (!(el instanceof Element)) return;

        const cardEl = el.closest<HTMLButtonElement>("[data-attendant]");
        if (!(cardEl && el.contains(cardEl))) return;

        const nextFlipped = (cardEl.dataset.flipped !== "true").toString();
        cardEl.dataset.flipped = nextFlipped;
        cardEl.setAttribute("aria-pressed", nextFlipped);
      };

      el.addEventListener("click", handleClick);
      return () => {
        destroyCarousel();
        el.removeEventListener("click", handleClick);
      };
    },
  });
</script>
