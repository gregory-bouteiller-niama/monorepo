---
import type { Disciplines } from "@niama/domain/functions/disciplines";
import { CarouselContent, CarouselItem, Carousel as CarouselNative, CarouselNext, CarouselPrevious } from "@niama/ui/astro/carousel.ts";
import { ItemContent, ItemDescription, ItemMedia, ItemTitle } from "@niama/ui/astro/item.ts";
import { Logo } from "@niama/ui/react/logo";
import { DISCIPLINE, DISCIPLINES } from "@niama/ui/shared/disciplines/carousel";
import Glow from "@/components/glow.astro";

// BASE ------------------------------------------------------------------------------------------------------------------------------------
const { items } = Astro.props;

// TYPES -----------------------------------------------------------------------------------------------------------------------------------
type Props = { items: Disciplines["Entity"][] };
---

<disciplines-carousel class={DISCIPLINES.base()}>
  <CarouselNative class={DISCIPLINES.carousel()}>
    <CarouselContent>
      {items.map((item) => (
          <CarouselItem class={DISCIPLINES.item()}>
            <Glow class={DISCIPLINE.base()} data-discipline={item.slug} kind="item" variant="outline">
              <ItemMedia class={DISCIPLINE.media()}>
                <Logo className={DISCIPLINE.logo()} discipline={item} />
              </ItemMedia>
              <ItemContent class={DISCIPLINE.content()}>
                <ItemTitle class={DISCIPLINE.title()}>{item.title}</ItemTitle>
                {item.description.map((sentence) => (
                  <ItemDescription class={DISCIPLINE.description()}>
                    {sentence}
                  </ItemDescription>
                ))}
              </ItemContent>
            </Glow>
          </CarouselItem>
        ))}
    </CarouselContent>
    <aside class={DISCIPLINES.controls()}>
      <CarouselPrevious class={DISCIPLINES.control()} />
      <CarouselNext class={DISCIPLINES.control()} />
    </aside>
  </CarouselNative>
</disciplines-carousel>

<script>
  import { defineCarousel, initCarousel } from "@niama/ui/astro/carousel.ts";
  import { AUTOPLAY } from "@niama/ui/shared/disciplines/carousel";
  import Autoplay from "embla-carousel-autoplay";

  defineCarousel({
    name: "disciplines-carousel",
    setup: (el) => initCarousel(el, { loop: true }, [Autoplay({ delay: AUTOPLAY })]),
  });
</script>
