{
  "name": "@niama/sveltekit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build && printf '_worker.js\\n' > .svelte-kit/cloudflare/.assetsignore",
    "preview": "bun run build && wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/cormorant-upright": "^5.2.7",
    "@fontsource/museomoderno": "^5.2.8",
    "@niama/backend": "workspace:*",
    "@niama/domain": "workspace:*",
    "@niama/ui": "workspace:*",
    "@tanstack/svelte-store": "^0.12.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-svelte": "^8.6.0",
    "svelte-sonner": "^1.1.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "wrangler": "^4.86.0"
  }
}
